// Prisma schema – SQLite (local)
// https://pris.ly/d/sqlite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  passwordHash String
  role         String   // "ADMIN" | "CASHIER"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique  // e.g. piece, box, kg, crate, dozen
  note      String?   // optional description
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  code          String    @unique  // SKU / barcode
  categoryId    Int
  category      Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  unit          String    // unit name from Unit table (e.g. piece, box, kg, crate)
  packInfo      String?   // e.g. "1 box = 100 pieces"
  costPrice     Int       // in Tsh
  sellingPrice  Int       // in Tsh
  stock         Int       @default(0)
  reorderLevel  Int       @default(20)
  taxRate       Float?    // optional, e.g. 0.18 for 18%
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
